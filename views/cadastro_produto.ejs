<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Cadastrar Produto</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #f4f6f9;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

/* CARD */
.container {
    background: white;
    padding: 25px;
    border-radius: 12px;
    width: 350px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

h2 {
    margin-bottom: 20px;
    text-align: center;
}

/* INPUTS */
input {
    width: 100%;
    padding: 10px;
    margin-bottom: 12px;
    border-radius: 6px;
    border: 1px solid #ccc;
}

/* BOTÃO */
button {
    width: 100%;
    padding: 10px;
    background: #27ae60;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
}

button:hover {
    background: #219150;
}

/* LINK VOLTAR */
a {
    display: block;
    text-align: center;
    margin-top: 10px;
    text-decoration: none;
    color: #2980b9;
}
</style>
</head>

<body>

<div class="container">
    <h2> Novo Produto</h2>

    <form action="/produtos/salvar" method="POST">
        <input type="text" name="nome" placeholder="Nome do produto" required>
        <input type="number" step="0.01" name="preco" placeholder="Preço" required>
        <input type="text" name="categoria" placeholder="Categoria" required>

        <button type="submit">Salvar Produto</button>
    </form>

    <a href="/">← Voltar</a>
</div>

</body>
</html>